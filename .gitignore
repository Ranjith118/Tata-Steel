# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
# Only ignore root-level dist/ and build/ (NOT frontend/dist which must be committed for Docker)
/dist/
/build/
.eggs/
*.egg

# Virtual environments
venv/
env/
.venv/
.env/

# Environment secrets — NEVER commit
backend/.env
.env
*.env

# Database (auto-created on startup)
backend/*.db
*.db

# Node
frontend/node_modules/
node_modules/

# Vite build output — keep committed so Docker can COPY it in
# frontend/dist/  ← intentionally NOT ignored

# ChromaDB / vector store (persistent at runtime, not in repo)
backend/chroma_db/
chroma_db/

# ML model artifacts (large binary files)
backend/models/*.pkl
backend/models/*.joblib

# Uploaded files
backend/data/
data/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
